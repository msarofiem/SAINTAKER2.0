// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id             String   @id @default(uuid())
  firstName      String
  lastName       String
  phoneNumber    String
  email          String?
  language       String   @default("English")
  source         String?
  typeOfAccident String
  dateOfAccident DateTime
  policeInvolved Boolean  @default(false)
  insurance      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  status         String   @default("New")

  // Relations
  address       Address?
  injuries      Injury[]
  priorAttorney PriorAttorney?
  uploads       Upload[]
  chaseLogs     ChaseLog[]
}

model Address {
  id        String   @id @default(uuid())
  street    String
  city      String
  state     String
  zip       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId String @unique
}

model Injury {
  id          String   @id @default(uuid())
  bodyPart    String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId String
}

model PriorAttorney {
  id           String   @id @default(uuid())
  spokenTo     Boolean  @default(false)
  firmName     String?
  attorneyName String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId String @unique
}

model Upload {
  id        String   @id @default(uuid())
  fileName  String
  fileType  String
  fileUrl   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId String
}

model ChaseLog {
  id           String    @id @default(uuid())
  type         String // Call, SMS, Email
  status       String // Pending, Completed, Failed
  notes        String?
  scheduledFor DateTime
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId String
}
