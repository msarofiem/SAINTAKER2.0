# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/sarofiem_intake?schema=public"

# JWT
JWT_SECRET="your-jwt-secret-key"

# Email
EMAIL_HOST="smtp.example.com"
EMAIL_PORT=587
EMAIL_USER="your-email@example.com"
EMAIL_PASS="your-email-password"
EMAIL_FROM="Sarofiem & Antoun <noreply@example.com>"

# OpenAI
OPENAI_API_KEY="your-openai-api-key"
OPENAI_MODEL="gpt-4-turbo"
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_TOKENS=1000

# Twilio
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"

# Frontend URL
FRONTEND_URL="http://localhost:3000"

# Server
PORT=3000
NODE_ENV="development"

# External Retainer API
RETAINER_API_SECRET="your-retainer-api-secret"
RETAINER_API_EXPIRY_DAYS=7

# Referral Marketplace
REFERRAL_MATCH_THRESHOLD=70
REFERRAL_AUTO_ASSIGN=false

# Client Mobile Portal
PUSH_NOTIFICATION_KEY="your-push-notification-key"
MOBILE_API_VERSION="v1"

# Insurance Carrier Portal
CARRIER_TOKEN_EXPIRY_DAYS=7
CARRIER_ACCESS_SECRET="your-carrier-access-secret"

# Marketing ROI Analytics
ANALYTICS_REFRESH_INTERVAL=3600
