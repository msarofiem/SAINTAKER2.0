// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id                   String    @id @default(uuid())
  firstName            String
  lastName             String
  phoneNumber          String
  email                String?
  language             String    @default("English")
  source               String?
  typeOfAccident       String
  dateOfAccident       DateTime
  policeInvolved       Boolean   @default(false)
  insurance            String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  status               String    @default("New")
  hasUmUimCoverage     Boolean   @default(false)
  hasResidentRelatives Boolean   @default(false)
  
  // Relations
  address              Address?
  injuries             Injury[]
  priorAttorney        PriorAttorney?
  uploads              Upload[]
  chaseLogs            ChaseLog[]
  portalAccess         ClientPortalAccess?
  liens                LienRecord[]
  
  // Phase 4 Relations
  evaluation           IntakeEvaluation?
  staffAssignment      StaffAssignment?
  touchpoints          ClientTouchpoint[]
  referrals            Referral[]
  carrierAccess        CarrierAccess[]
}

model Address {
  id        String   @id @default(uuid())
  street    String
  city      String
  state     String
  zip       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId    String   @unique
}

model Injury {
  id            String   @id @default(uuid())
  bodyPart      String
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  lead          Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId        String
}

model PriorAttorney {
  id            String   @id @default(uuid())
  spokenTo      Boolean  @default(false)
  firmName      String?
  attorneyName  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  lead          Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId        String   @unique
}

model Upload {
  id            String   @id @default(uuid())
  fileName      String
  fileType      String
  fileUrl       String
  documentType  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  lead          Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId        String
  signatures    DocumentSignature[]
}

model ChaseLog {
  id            String   @id @default(uuid())
  type          String   // Call, SMS, Email
  status        String   // Pending, Completed, Failed
  notes         String?
  scheduledFor  DateTime
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  lead          Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId        String
}

model ClientPortalAccess {
  id            String    @id @default(uuid())
  token         String    @unique
  pin           String?
  expiresAt     DateTime
  accessedAt    DateTime?
  ipAddress     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  lead          Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId        String    @unique
}

model DocumentSignature {
  id              String    @id @default(uuid())
  status          String    // pending, signed, uploaded, failed
  signedAt        DateTime?
  ipAddress       String?
  signatureToken  String?   @unique
  signerName      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  document        Upload    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId      String
}

model LienRecord {
  id            String    @id @default(uuid())
  lienType      String    // Medicare, Medicaid, Private
  lienHolder    String
  amount        Float?
  status        String    // pending, received, negotiated, paid
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  lead          Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId        String
}

// New models for Phase 4

model IntakeEvaluation {
  id              String    @id @default(uuid())
  score           Int       // 0-100 score
  recommendation  String    // Accept, Review, Reject
  redFlags        String?
  strengths       String?
  aiResponse      String?   // Full GPT response
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  lead            Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId          String    @unique
}

model StaffAssignment {
  id              String    @id @default(uuid())
  isActive        Boolean   @default(true)
  assignedAt      DateTime  @default(now())
  language        String?
  updatedAt       DateTime  @updatedAt
  
  // Relations
  lead            Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId          String    @unique
  staff           StaffMember @relation(fields: [staffId], references: [id])
  staffId         String
}

model StaffMember {
  id              String    @id @default(uuid())
  name            String
  email           String    @unique
  languages       String[]  // Array of languages spoken
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  assignments     StaffAssignment[]
}

model ClientTouchpoint {
  id              String    @id @default(uuid())
  type            String    // SMS, Email
  status          String    // Pending, Sent, Failed
  messageContent  String
  scheduledFor    DateTime
  sentAt          DateTime?
  deliveryMethod  String?   // Twilio, Email
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  lead            Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId          String
}

model ReferralFeedback {
  id              String    @id @default(uuid())
  status          String    // Pending, Accepted, Declined
  fee             Float?
  comments        String?
  responseAt      DateTime?
  lastReminderAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  referral        Referral  @relation(fields: [referralId], references: [id], onDelete: Cascade)
  referralId      String    @unique
}

model Referral {
  id              String    @id @default(uuid())
  referredTo      String
  referralDate    DateTime  @default(now())
  email           String
  phoneNumber     String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  lead            Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId          String
  feedback        ReferralFeedback?
}

model CarrierAccess {
  id              String    @id @default(uuid())
  carrierName     String
  carrierEmail    String
  accessToken     String    @unique
  expiresAt       DateTime
  lastAccessedAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  lead            Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId          String
}
